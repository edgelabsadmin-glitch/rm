# EDGE Pulse — environment template (SPEC-001 / build-plan §3 step 5)
# Copy to .env (gitignored) and populate. load_dotenv(override=True) everywhere (Q116).

# ── LLM (ADR / Decision 13: Claude primary; OpenAI embeddings only) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                      # embeddings only (text-embedding-3-small, Spike 3 §C)

# ── Salesforce (production-org dev under read-only ingestion, §4.14) ──
# Auth via `sf` CLI alias `edgesolutions` (edgelabs.admin@onedge.co). API pinned v62.0 (§6 rule 17).
# These are only needed if a code path uses simple-salesforce instead of the sf CLI.
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_TARGET_ORG=edgesolutions

# ── Chorus ──
CHORUS_API_TOKEN=

# ── Postgres (Supabase free tier; schemas: pulse / activepieces / langfuse) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=                        # postgres connection string for the `pulse` schema

# ── Observability (ADR-003: Langfuse self-hosted on Fly.io) ──
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Workflow engine (ADR-002: Activepieces self-hosted on Fly.io) ──
ACTIVEPIECES_API_URL=
ACTIVEPIECES_API_TOKEN=
PULSE_INTERNAL_API_TOKEN=            # shared secret: Activepieces flows → FastAPI /internal/*

# ── Auth (Design 09 ADR-006: Google Workspace OAuth via Supabase Auth) ──
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── opportunity-tracker integration safety guard (SPEC-004 / Q121) ──
# Leave UNSET in production. Setting to 'true' re-enables opp-tracker's dormant
# direct-SFDC-write path, which violates §6 rule 6. Do not set unless deliberately overriding.
# PULSE_ALLOW_OPP_TRACKER_SFDC_WRITE=
