# SPEC-001 — pulse-api container (ADR-001 / ADR-008 single-VPS→Fly.io).
FROM python:3.12-slim

WORKDIR /app
COPY pyproject.toml ./
RUN pip install --no-cache-dir -e .

COPY api ./api
COPY core ./core
COPY scripts ./scripts

EXPOSE 8000
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
